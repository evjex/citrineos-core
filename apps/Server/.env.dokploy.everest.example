# Everest app env (Dokploy)
# Recommended: compose mode with docker-compose.dokploy-everest.yml
# This app requires 3 services on one network: manager + mqtt-server + nodered.
OCPP_VERSION=2.1
EVEREST_TARGET_URL=wss://ocpp.rangoru.com/cp001
EVEREST_CHARGE_POINT_ID=cp001
EVEREST_IMAGE_TAG=2025.6.1-dt-esdp
# Optional mirror when this exact tag has been synchronized internally.
EVEREST_IMAGE_REPOSITORY=git.samasha.ir/samasha/everest-manager
# Compose mode default is "mqtt-server".
# For split image apps, use MQTT_SERVER_ADDRESS in each app env instead.
EVEREST_MQTT_SERVER_ADDRESS=mqtt-server
# For OCPP 2.0.1 keep the default below.
# For OCPP 1.6 use: /config/config-sil-one-evse-flow.json
EVEREST_NODERED_FLOWS=/config/config-sil-two-evse-flow.json
